DJANGO_SETTINGS_MODULE=config.settings.development
DJANGO_SECRET_KEY=replace-with-a-random-secret
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
DATABASE_URL=postgresql://wakeupcall:wakeupcall@localhost:5432/wakeupcall
# Production ECS may inject these separately instead of DATABASE_URL.
DATABASE_HOST=
DATABASE_NAME=
DATABASE_USER=
DATABASE_PASSWORD=
DATABASE_PORT=5432

POSTGRES_DB=wakeupcall
POSTGRES_USER=wakeupcall
POSTGRES_PASSWORD=wakeupcall

WEATHER_API_KEY=replace-with-your-weatherapi-key
WEATHER_API_BASE_URL=https://api.weatherapi.com/v1
WEATHER_API_CONNECT_TIMEOUT=2.0
WEATHER_API_READ_TIMEOUT=5.0

TWILIO_ACCOUNT_SID=replace-with-your-account-sid
TWILIO_AUTH_TOKEN=replace-with-your-auth-token
TWILIO_VERIFY_SERVICE_SID=replace-with-your-verify-service-sid
TWILIO_SMS_FROM_NUMBER=replace-with-your-twilio-number
TWILIO_SMS_INBOUND_CALLBACK_URL=https://example.com/twilio/sms/inbound/
TWILIO_HTTP_TIMEOUT=5.0
TWILIO_SMS_SMOKE_ENABLED=false
TWILIO_SMS_SMOKE_TO_NUMBER=replace-with-an-authorized-staging-number
TWILIO_VOICE_FROM_NUMBER=replace-with-your-twilio-number
TWILIO_VOICE_STATUS_CALLBACK_URL=https://example.com/twilio/voice/status/
TWILIO_VOICE_ACTION_CALLBACK_URL=https://example.com/twilio/voice/action/
TWILIO_VOICE_SMOKE_ENABLED=false
TWILIO_VOICE_SMOKE_TO_NUMBER=replace-with-an-authorized-staging-number

DELIVERY_DISPATCH_BATCH_SIZE=25
DELIVERY_MISSED_GRACE_MINUTES=15
DELIVERY_REAL_DISPATCH_ENABLED=false

AWS_REGION=us-east-1
DELIVERY_QUEUE_URL=
DELIVERY_QUEUE_CONNECT_TIMEOUT=2.0
DELIVERY_QUEUE_READ_TIMEOUT=25.0
DELIVERY_QUEUE_RECEIVE_BATCH_SIZE=10
DELIVERY_QUEUE_WAIT_SECONDS=20
DELIVERY_QUEUE_VISIBILITY_SECONDS=120
DELIVERY_QUEUE_MAX_RECEIVES=3
DELIVERY_QUEUE_RETRY_BASE_SECONDS=30
DELIVERY_QUEUE_RETRY_MAX_SECONDS=300
DELIVERY_REAL_WORKER_ENABLED=false
